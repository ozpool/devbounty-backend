# DevBounty API — environment variable reference
# Copy to .env and fill in real values. Never commit .env.
#
# Vars marked [required:prod] must be set in production.
# Vars marked [optional] have safe defaults for local dev.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | test | production
LOG_LEVEL=info                        # fatal | error | warn | info | debug | trace
PORT=4000                             # [optional] HTTP port

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/devbounty   # [required:prod]

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret   # [required:prod] HS256 signing key, min 32 chars
JWT_COOKIE_NAME=devbounty_jwt                  # [optional] httpOnly cookie name

# ── Chain ─────────────────────────────────────────────────────────────────────
CHAIN_ID=421614                                # [optional] Arbitrum Sepolia chain ID
RPC_URL_HTTP=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY   # [required:prod]
RPC_URL_HTTP_FALLBACK=https://arbitrum-sepolia.infura.io/v3/YOUR_KEY  # [optional]

# ── Internal services ─────────────────────────────────────────────────────────
API_PUBLIC_BASE_URL=https://api.devbounty.example  # [required:prod]
CORS_ORIGIN=https://devbounty.example              # [required:prod] strict CORS allowlist
INTERNAL_HEALTH_TOKEN=change-me-random-token       # [required:prod] Bearer token for /health/internal, min 16 chars

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=                                    # [optional] Sentry DSN — full wiring in later issue

# ── Encryption at rest (AES-256-GCM) ──────────────────────────────────────────
# Keys are 32 bytes in hex (generate with: openssl rand -hex 32). Versioning lets
# you rotate: add ENC_KEY_V2, flip ENC_ACTIVE_KEY_VERSION to v2; old data still
# decrypts under v1.
ENC_ACTIVE_KEY_VERSION=v1                      # [optional] version used for new writes
ENC_KEY_V1=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff  # [required:prod] 32-byte hex
ENC_KEY_V2=                                    # [optional] second key during rotation

# ── GitHub OAuth (account linking) ────────────────────────────────────────────
# Create an OAuth app; callback is <API_PUBLIC_BASE_URL>/auth/github/callback.
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id       # [required:prod]
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret  # [required:prod]
GITHUB_OAUTH_SCOPES=read:user repo                       # [optional] space-separated
