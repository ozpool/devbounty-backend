{
  "name": "@devbounty/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "DevBounty Express API + chain indexer (two entrypoints, one package).",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev:indexer": "tsx watch --env-file-if-exists=.env src/indexer/index.ts",
    "start:api": "node --env-file-if-exists=.env dist/index.js",
    "start:indexer": "node --env-file-if-exists=.env dist/indexer/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^8.42.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "viem": "^2.21.58",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
